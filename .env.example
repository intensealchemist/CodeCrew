# ============================================
# CodeCrew - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.

# --- Multi-GPU Distributed Ollama Routing ---
# Each agent role routes to its own Ollama endpoint (Kaggle/Colab GPU instance).
# If a per-role URL is not set, it falls back to OLLAMA_BASE_URL.
#
# Role Assignments:
#   reasoning  → Researcher agent           (deepseek-r1:14b)
#   coding     → Coder agent                (qwen2.5-coder:14b)
#   structured → Spec Validator, Architect,
#                File Planner               (qwen2.5:7b)
#   qa         → QA Agent, README Agent     (qwen2.5:7b)

# Shared fallback (used if per-role URLs are not set)
OLLAMA_BASE_URL=http://localhost:11434

# Per-role Ollama endpoints (each is a separate GPU instance)
OLLAMA_URL_REASONING=https://your-kaggle-1.ngrok-free.app
OLLAMA_URL_CODING=https://your-kaggle-2.ngrok-free.app
OLLAMA_URL_STRUCTURED=https://your-colab.ngrok-free.app

# Embedding endpoint for retrieval
# If not set, falls back to OLLAMA_BASE_URL
OLLAMA_EMBED_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Search Provider ---
# Options: duckduckgo
SEARCH_PROVIDER=duckduckgo

# --- LLM Provider ---
LLM_PROVIDER=free_ha
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENAI_API_KEY=
AGENTSCOPE_USE_STUDIO=false
STUDIO_URL=http://127.0.0.1:5000

# --- Retrieval / RAG ---
# Retrieval mode: hybrid, semantic, keyword
CODECREW_RAG_RETRIEVAL_MODE=hybrid
# Vector backend: memory, chroma, lancedb
CODECREW_RAG_VECTOR_BACKEND=memory
# Path used by persistent vector backends like ChromaDB or LanceDB
CODECREW_RAG_VECTOR_BACKEND_PATH=
# Reranker: auto, flashrank, none
CODECREW_RAG_RERANKER=auto
CODECREW_RAG_FLASHRANK_MODEL=ms-marco-MiniLM-L-12-v2
CODECREW_RAG_SEMANTIC_WEIGHT=0.6
CODECREW_RAG_KEYWORD_WEIGHT=0.4
CODECREW_RAG_CHUNK_SIZE=800
CODECREW_RAG_CHUNK_OVERLAP=120
# Evaluation provider: heuristic, ragas, deepeval
CODECREW_RAG_EVALUATOR=heuristic
# Optional retrieval tracing
CODECREW_RAG_TRACE=false
CODECREW_RAG_TRACE_PATH=

# --- Job Queue (Multi-User) ---
REDIS_URL=redis://localhost:6379/0
