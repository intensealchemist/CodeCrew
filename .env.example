# ============================================
# CodeCrew - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.

# --- LLM Provider ---
# Options: ollama | groq | free_ha | openai | anthropic
LLM_PROVIDER=ollama

# Free High Availability (Zero-Cost Failover)
# Combines Groq, Cerebras, and Gemini. Falls back automatically if rate limited.
# To use: Set LLM_PROVIDER=free_ha and provide at least two keys below.
# Pro Tip: You can provide MULTIPLE keys separated by commas for endless failover!
# Example: GROQ_API_KEYS="key1,key2,key3"

# Ollama (default, free, local)
# Make sure Ollama is running: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Groq (free tier, fast cloud API)
# Get your key at: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Cerebras (free tier, fast inference)
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

# Gemini (free tier)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (paid)
OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o

# Anthropic (paid)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Search Provider ---
# Options: duckduckgo | serper | tavily | exa
# duckduckgo is free and requires no API key (default)
SEARCH_PROVIDER=duckduckgo

# Serper (https://serper.dev)
SERPER_API_KEY=

# Tavily (https://tavily.com)
TAVILY_API_KEY=

# Exa (https://exa.ai)
EXA_API_KEY=

# --- Job Queue (Multi-User) ---
# Requires Celery & Redis. Install via: pip install "codecrew[queue]"
# Get a free Redis URL at https://upstash.com or run locally
REDIS_URL=redis://localhost:6379/0
